<head><meta charset="utf-8">
<style>
body { font-family: Calibri, sans-serif; font-size: 11pt; color: #2d2d2d; margin: 1in; }
h1 { font-size: 20pt; color: #981e32; border-bottom: 3px solid #981e32; padding-bottom: 8px; }
h2 { font-size: 14pt; color: #981e32; margin-top: 24px; }
h3 { font-size: 12pt; color: #5f6b6d; }
.step { margin: 12px 0; padding: 8px 12px; background: #f5f5f5; border-left: 4px solid #981e32; }
.step-num { font-weight: bold; color: #981e32; }
.tip { margin: 12px 0; padding: 8px 12px; background: #f0f9ff; border-left: 4px solid #3b82f6; }
.tip-label { font-weight: bold; color: #0c4a6e; }
.warning { margin: 12px 0; padding: 8px 12px; background: #fef2f2; border-left: 4px solid #dc2626; }
.code { font-family: Consolas, monospace; font-size: 10pt; background: #f5f5f5; padding: 8px 12px; border: 1px solid #e5e7eb; margin: 8px 0; display: block; }
table { border-collapse: collapse; width: 100%; margin: 12px 0; }
